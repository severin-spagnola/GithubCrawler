# --- RunPod orchestrator (runpod_orchestrator.py) ---
NGROK_AUTH_TOKEN=your_ngrok_auth_token
QUERIES_FILE=./queries.txt
OUTPUT_FILE=./final_leads.csv
ORCHESTRATOR_DB=./orchestrator.db

# --- RunPod worker env vars (set in RunPod template, not here) ---
# ORCHESTRATOR_URL=https://xxxx.ngrok-free.app
# GITHUB_TOKEN=ghp_worker_token
# WORKER_ID=worker-1
# BATCH_SIZE=3
# ENRICH_LEADS=1
# MAX_IDLE_POLLS=30

# --- Shared ---
QUERIES_FILE=./queries.txt
RESULTS_DIR=./results
OUTPUT_FILE=./final_leads.csv
